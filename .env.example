# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=Cached Data API
APP_VERSION=1.0.0
DEBUG=false

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_DB=financial_db

DATABASE_URL=postgresql+asyncpg://postgres:your-strong-password-here@localhost:5432/financial_db
DATABASE_URL_SYNC=postgresql://postgres:your-strong-password-here@localhost:5432/financial_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_KEY_PREFIX=cached_data_api
REDIS_TTL_DEFAULT=300
